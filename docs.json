  "head": [
    "<link href=\"https://fonts.googleapis.com/css2?family=Poppins:wght@600;700&family=Manrope:wght@400;500;600;700&display=swap\" rel=\"stylesheet\">",
    "<script>(function(){function applyNav(){var n=document.getElementById('navbar');var t=document.getElementById('navbar-transition');if(n){n.style.setProperty('background','#0061FC','important');}if(t){t.style.setProperty('background','transparent','important');t.style.setProperty('backdrop-filter','none','important');t.style.setProperty('-webkit-backdrop-filter','none','important');t.style.setProperty('border-bottom-color','rgba(255,255,255,0.15)','important');}document.querySelectorAll('#navbar a,#navbar button').forEach(function(el){el.style.setProperty('color','rgba(255,255,255,0.9)','important');});document.querySelectorAll('#navbar svg').forEach(function(el){el.style.setProperty('stroke','rgba(255,255,255,0.9)','important');el.style.setProperty('color','rgba(255,255,255,0.9)','important');});document.querySelectorAll('#navbar img.nav-logo').forEach(function(el){el.style.setProperty('filter','brightness(0) invert(1)','important');});}document.addEventListener('DOMContentLoaded',function(){applyNav();var t=document.getElementById('navbar-transition');if(t)new MutationObserver(applyNav).observe(t,{attributes:true,attributeFilter:['data-is-opaque']});});})();</script>"
  ],
  "custom": {
    "css": "@import url('https://fonts.googleapis.com/css2?family=Poppins:wght@600;700&family=Manrope:wght@400;500;600;700&display=swap'); .rm-ReferenceMain .parameterField, .rm-ReferenceMain .returns, .rm-ReferenceMain h2 { background: #F4F3EF; border-radius: 8px; padding: 12px 16px; } h1[style] { font-family: 'Poppins', sans-serif !important; } p[style], a[style] { font-family: 'Manrope', sans-serif !important; } #navbar { background: #0061FC; --background-light: 0 97 252; --gray-200: 200 215 240; --gray-300: 220 230 250; --gray-400: 200 215 240; --gray-500: 200 215 240; --gray-600: 230 240 255; --gray-700: 245 248 255; --gray-800: 255 255 255; --gray-900: 255 255 255; } #navbar #search-bar-entry, #navbar #assistant-entry { --background-light: 255 255 255; } #navbar .nav-tabs-item > div { --primary: 255 255 255; --gray-200: 255 255 255; } #navbar img.nav-logo { filter: brightness(0) invert(1); }"
  }
